{
  "componentName": "NewsArticleMediaBlock",
  "atomicType": "molecule",
  "childComponents": [],
  "description": "Drupal layout builder block that renders a responsive hero/featured image for a news article, with an optional caption.",
  "rootElement": "section",
  "rootClassName": "block-field-blocknodenews-articlefield-n-media",
  "selectorsCovered": [
    ".block-field-blocknodenews-articlefield-n-media",
    ".block-field-blocknodenews-articlefield-n-media .media--image--figure",
    ".block-field-blocknodenews-articlefield-n-media figure.imgcapt"
  ],
  "props": [
    {
      "name": "srcMobile1x",
      "type": "string",
      "required": true,
      "mapsTo": { "element": "source:last-of-type", "attribute": "srcset" }
    },
    {
      "name": "srcTablet1x",
      "type": "string",
      "required": true,
      "mapsTo": { "element": "source:nth-of-type(3)", "attribute": "srcset" }
    },
    {
      "name": "srcDesktop1x",
      "type": "string",
      "required": true,
      "mapsTo": { "element": "source:nth-of-type(2)", "attribute": "srcset" }
    },
    {
      "name": "srcWide1x",
      "type": "string",
      "required": true,
      "mapsTo": { "element": "source:first-of-type", "attribute": "srcset" }
    },
    {
      "name": "imgSrc",
      "type": "string",
      "required": true,
      "mapsTo": { "element": "img", "attribute": "src" }
    },
    {
      "name": "imgAlt",
      "type": "string",
      "required": true,
      "mapsTo": { "element": "img", "attribute": "alt" }
    },
    {
      "name": "caption",
      "type": "string",
      "required": false,
      "mapsTo": { "element": "figcaption", "attribute": "innerText" }
    }
  ],
  "subcomponents": [],
