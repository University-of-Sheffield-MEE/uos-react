{
  "componentName": "VideoEmbedLazy",
  "atomicType": "molecule",
  "childComponents": [],
  "description": "A lazy-loaded video embed that shows a thumbnail image and play button; clicking loads the embedded iframe from a data attribute.",
  "rootElement": "div",
  "rootClassName": "video-embed-field-lazy",
  "selectorsCovered": [
    ".video-embed-field-lazy",
    ".video-embed-field-lazy-play"
  ],
  "props": [
    {
      "name": "thumbnailSrc",
      "type": "string",
      "required": true,
      "mapsTo": { "element": "img", "attribute": "src" }
    },
    {
      "name": "thumbnailAlt",
      "type": "string",
      "required": false,
      "default": "",
      "mapsTo": { "element": "img", "attribute": "alt" }
    },
    {
      "name": "thumbnailWidth",
      "type": "number",
      "required": false,
      "default": 752,
      "mapsTo": { "element": "img", "attribute": "width" }
    },
    {
      "name": "thumbnailHeight",
      "type": "number",
      "required": false,
      "default": 423,
      "mapsTo": { "element": "img", "attribute": "height" }
    },
    {
      "name": "embedHtml",
      "type": "string",
      "required": true,
      "mapsTo": { "element": "div.video-embed-field-lazy", "attribute": "data-video-embed-field-lazy" }
    }
  ],
  "subcomponents": [],
