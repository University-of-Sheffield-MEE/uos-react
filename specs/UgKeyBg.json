{
  "componentName": "UgKeyBg",
  "atomicType": "organism",
  "childComponents": [],
  "description": "Undergraduate course key details banner displaying course title, award type, department, entry requirements, key feature tags, and call-to-action buttons — present on every UG course page.",
  "rootElement": "div",
  "rootClassName": "ugkeybg",
  "selectorsCovered": [
    "#main .ugkeybg",
    "#main .ugkeybg .title-box",
    "#main .ugkeybg .title-box .startyr",
    "#main .ugkeybg .title-box h1",
    "#main .ugkeybg .title-box .left",
    "#main .ugkeybg .title-box .left .text",
    "#main .ugkeybg .title-box .left .keydetails ul.details",
    "#main .ugkeybg .title-box .left .keydetails ul.details > li",
    "#main .ugkeybg .title-box .left .keydetails ul.details > li span",
    "#main .ugkeybg .title-box .left .keydetails ul.details > li span.alevels",
    "#main .ugkeybg .title-box .left .keydetails ul.details > li span.ucascode",
    "#main .ugkeybg .title-box .left .keydetails ul.details > li span.duration",
    "#main .ugkeybg .title-box .left .keydetails ul.details > li span.startdate",
    "#main .ugkeybg .title-box .left .keydetails ul.details > li span.attendance",
    "#main .ugkeybg .title-box .left .keydetails ul.features",
    "#main .ugkeybg .title-box .left .keydetails ul.features li",
    "#main .ugkeybg .title-box .left .keydetails ul.features li a",
    "#main .ugkeybg .title-box .topdetail",
    "#main .ugkeybg .title-box .topdetail h1",
    "#main .ugkeybg .title-box .topdetail .award-type",
    "#main .ugkeybg .title-box .topdetail div",
    "#main .ugkeybg .title-box .summary",
    "#main .ugkeybg .title-box .buttons",
    "#main .ugkeybg .sticky-ctas",
    "#main .ugkeybg .sticky-ctas .ugbuttons",
    "#main .ugkeybg .sticky-ctas .shrinkctas",
    "#main .ugkeybg .sticky-ctas .ugbuttons .stickybutton",
    "#main .ugkeybg .sticky-ctas .stickybutton",
    "#main .ugkeybg .sticky-ctas.on-load",
    "#main .ugkeybg .title-box .altentry a",
    "#main .ugkeybg .title-box .left .keydetails ul.features li .fy"
  ],
  "props": [
    {
      "name": "startYear",
      "type": "string",
      "required": true,
      "mapsTo": { "element": ".title-box .startyr", "attribute": "innerText" }
    },
    {
      "name": "altEntryLabel",
      "type": "string",
      "required": false,
      "mapsTo": { "element": ".altentry a", "attribute": "innerText" }
    },
    {
      "name": "altEntryHref",
      "type": "string",
      "required": false,
      "mapsTo": { "element": ".altentry a", "attribute": "href" }
    },
    {
      "name": "courseTitle",
      "type": "string",
      "required": true,
      "mapsTo": { "element": ".fb-award-title", "attribute": "innerText" }
    },
    {
      "name": "awardType",
      "type": "string",
      "required": true,
      "mapsTo": { "element": ".award-type", "attribute": "innerText" }
    },
    {
      "name": "department",
      "type": "string",
      "required": true,
      "mapsTo": { "element": ".fb-award-department", "attribute": "innerText" }
    },
    {
      "name": "summary",
      "type": "string",
      "required": true,
      "mapsTo": { "element": ".fb-award-summary", "attribute": "innerText" }
    },
    {
      "name": "aLevels",
      "type": "string",
      "required": true,
      "mapsTo": { "element": ".fb-award-alevels", "attribute": "innerText" }
    },
    {
      "name": "ucasCode",
      "type": "string",
      "required": true,
      "mapsTo": { "element": ".fb-award-ucascode", "attribute": "innerText" }
    },
    {
      "name": "duration",
      "type": "string",
      "required": true,
      "mapsTo": { "element": "ul.details li:nth-child(3) .fb-award-duration", "attribute": "innerText" }
    },
    {
      "name": "startDate",
      "type": "string",
      "required": true,
      "mapsTo": { "element": "ul.details li:nth-child(4) .fb-award-duration", "attribute": "innerText" }
    },
    {
      "name": "attendance",
      "type": "string",
      "required": false,
      "mapsTo": { "element": "ul.details li:nth-child(5) .fb-award-duration", "attribute": "innerText" }
    },
    {
      "name": "featureAccredited",
      "type": "boolean",
      "required": false,
      "default": false
    },
    {
      "name": "featureFees",
      "type": "boolean",
      "required": false,
      "default": false
    },
    {
      "name": "featureFundingAvailable",
      "type": "boolean",
      "required": false,
      "default": false
    },
    {
      "name": "featureOptionalPlacementYear",
      "type": "boolean",
      "required": false,
      "default": false
    },
    {
      "name": "featureStudyAbroadOption",
      "type": "boolean",
      "required": false,
      "default": false
    },
    {
      "name": "featureStudyAbroad",
      "type": "boolean",
      "required": false,
      "default": false
    },
    {
      "name": "featureSandwichYear",
      "type": "boolean",
      "required": false,
      "default": false
    },
    {
      "name": "buttons",
      "type": "Array<{ label: string; href: string; className?: string }>",
      "required": true,
      "mapsTo": { "element": ".buttons .uosbutton", "attribute": "href" }
    },
    {
      "name": "stickyButtons",
      "type": "Array<{ label: string; href: string; iconClass: string }>",
      "required": true,
      "mapsTo": { "element": ".ugbuttons .stickybutton", "attribute": "href" }
    }
  ],
  "subcomponents": [],
