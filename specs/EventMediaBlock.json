{
  "componentName": "EventMediaBlock",
  "atomicType": "molecule",
  "childComponents": [],
  "description": "Drupal layout builder block that renders a responsive hero/featured image for an event node, with an optional caption.",
  "rootElement": "div",
  "rootClassName": "block-field-blocknodeeventfield-ev-media",
  "selectorsCovered": [
    ".block-field-blocknodeeventfield-ev-media",
    ".block-field-blocknodeeventfield-ev-media .media--image--figure",
    ".block-field-blocknodeeventfield-ev-media figure.imgcapt"
  ],
  "props": [
    {
      "name": "srcWide1x",
      "type": "string",
      "required": true,
      "mapsTo": { "element": "source:first-of-type", "attribute": "srcset" }
    },
    {
      "name": "srcDesktop1x",
      "type": "string",
      "required": true,
      "mapsTo": { "element": "source:nth-of-type(2)", "attribute": "srcset" }
    },
    {
      "name": "srcTablet1x",
      "type": "string",
      "required": true,
      "mapsTo": { "element": "source:nth-of-type(3)", "attribute": "srcset" }
    },
    {
      "name": "srcMobile1x",
      "type": "string",
      "required": true,
      "mapsTo": { "element": "source:last-of-type", "attribute": "srcset" }
    },
    {
      "name": "imgSrc",
      "type": "string",
      "required": true,
      "mapsTo": { "element": "img", "attribute": "src" }
    },
    {
      "name": "imgAlt",
      "type": "string",
      "required": true,
      "mapsTo": { "element": "img", "attribute": "alt" }
    },
    {
      "name": "caption",
      "type": "string",
      "required": false,
      "mapsTo": { "element": "figcaption", "attribute": "innerText" }
    }
  ],
  "subcomponents": [],
