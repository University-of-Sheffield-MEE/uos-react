{
  "componentName": "ParaSignpostBox",
  "atomicType": "molecule",
  "childComponents": [],
  "description": "A Drupal paragraph signpost box component that renders a clickable card with an image and a titled arrow link, used to navigate users to related content.",
  "rootElement": "div",
  "rootClassName": "paragraph--type--para-signpost-box",
  "selectorsCovered": [
    ".paragraph--type--para-signpost-box",
    ".paragraph--type--para-signpost-box > a",
    ".paragraph--type--para-signpost-box .block-field-blockparagraphpara-signpost-boxfield-sb-title",
    ".paragraph--type--para-signpost-box .block-field-blockparagraphpara-signpost-boxfield-sb-title .sbtitle",
    ".paragraph--type--para-signpost-box .block-field-blockparagraphpara-signpost-boxfield-sb-title .sbarrow",
    ".paragraph--type--para-signpost-box.dark",
    ".paragraph--type--para-signpost-box.dark .block-field-blockparagraphpara-signpost-boxfield-sb-title",
    ".paragraph--type--para-signpost-box.highlight",
    ".paragraph--type--para-signpost-box.highlight .block-field-blockparagraphpara-signpost-boxfield-sb-title",
    ".paragraph--type--para-signpost-box.highlight .block-field-blockparagraphpara-signpost-boxfield-sb-title .sbarrow",
    ".multicol .medium-4 .paragraph--type--para-signpost-box",
    ".multicol .medium-4 .paragraph--type--para-signpost-box .block-field-blockparagraphpara-signpost-boxfield-sb-title"
  ],
  "props": [
    {
      "name": "href",
      "type": "string",
      "required": true,
      "mapsTo": { "element": "a", "attribute": "href" }
    },
    {
      "name": "ariaLabel",
      "type": "string",
      "required": true,
      "mapsTo": { "element": "a", "attribute": "aria-label" }
    },
    {
      "name": "title",
      "type": "string",
      "required": true,
      "mapsTo": { "element": ".sbtitle", "attribute": "innerText" }
    },
    {
      "name": "imageSrc",
      "type": "string",
      "required": true,
      "mapsTo": { "element": "img", "attribute": "src" }
    },
    {
      "name": "imageAlt",
      "type": "string",
      "required": true,
      "mapsTo": { "element": "img", "attribute": "alt" }
    },
    {
      "name": "dark",
      "type": "boolean",
      "required": false,
      "default": false,
      "mapsTo": { "togglesClass": "dark", "on": "root" }
    },
    {
      "name": "highlight",
      "type": "boolean",
      "required": false,
      "default": false,
      "mapsTo": { "togglesClass": "highlight", "on": "root" }
    }
  ],
  "subcomponents": [],
