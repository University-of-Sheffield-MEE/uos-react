{"componentName":"FootIcons","atomicType":"organism","childComponents":[],"description":"Footer section displaying university award badge images and social media icon links in two grouped rows.","rootElement":"div","rootClassName":"footicons","selectorsCovered":[".footicons",".footicons .awards",".footicons .awards a",".footicons .awards a > img",".footicons .social a",".region-footer_last"],"props":[{"name":"awardLinks","type":"Array<{ href: string; src: string; alt: string }>","required":true,"mapsTo":{"element":".awards a","attribute":"href"}},{"name":"socialLinks","type":"Array<{ href: string; src: string; alt: string }>","required":true,"mapsTo":{"element":".social a","attribute":"href"}}],"subcomponents":[],"stories":[{"name":"Default","description":"Standard footer icons section with award badges and social media links","props":{"awardLinks":[{"href":"//www.sheffield.ac.uk/about/rankings","src":"/themes/custom/common/uos/images/WORLD100_stamp_white.png","alt":"A World Top 100 University"},{"href":"//www.sheffield.ac.uk/about/rankings","src":"/themes/custom/common/uos/images/russell.png","alt":"Russell Group"},{"href":"//www.sheffield.ac.uk/about/queens-prize","src":"/themes/custom/common/uos/images/QAP.png","alt":"Five Queen's Anniversary Prizes"}],"socialLinks":[{"href":"https://instagram.com/theuniversityofsheffield","src":"//cdn.sheffield.ac.uk/sites/default/files/styles/original/public/2022-10/social-in.png","alt":"Instagram logo"},{"href":"https://www.linkedin.com/school/university-of-sheffield/","src":"//cdn.sheffield.ac.uk/sites/default/files/styles/original/public/2022-10/social-li.png","alt":"LinkedIn"},{"href":"https://www.tiktok.com/@sheffielduni","src":"//cdn.sheffield.ac.uk/sites/default/files/styles/original/public/2022-10/social-tt.png","alt":"TikTok"},{"href":"https://bsky.app/profile/sheffielduni.bsky.social","src":"/sites/default/files/styles/original/public/2025-10/social-icon-bluesky2.png","alt":"Bluesky butterfly logo"},{"href":"https://www.threads.com/@theuniversityofsheffield","src":"/sites/default/files/styles/original/public/2025-10/social-icon-threads.png","alt":"Threads logo"},{"href":"https://www.weibo.com/sheffielduni","src":"//cdn.sheffield.ac.uk/sites/default/files/styles/original/public/2022-10/social-wb.png","alt":"Weibo"}]}}],"notes":"The .region-footer_last div wraps the .social content inside .footicons. Award badges and social media icons are both rendered as linked images. All links and images are consistent across pages (duplicates: 5, textVaries: false) — they represent fixed institutional branding, but are modelled as props for flexibility. The .embedded-entity and .media--image--figure wrappers are Drupal CMS artefacts and should not be reproduced in the React component; render img tags directly inside anchor tags.","htmlExamples":["<div class=\"footicons\">\n  <div class=\"awards\">\n    <a href=\"//www.sheffield.ac.uk/about/rankings\"><img src=\"/themes/custom/common/uos/images/WORLD100_stamp_white.png\" loading=\"lazy\" alt=\"A World Top 100 University\"></a>\n    <a href=\"//www.sheffield.ac.uk/about/rankings\"><img src=\"/themes/custom/common/uos/images/russell.png\" loading=\"lazy\" alt=\"Russell Group\"></a>\n    <a href=\"//www.sheffield.ac.uk/about/queens-prize\"><img src=\"/themes/custom/common/uos/images/QAP.png\" loading=\"lazy\" alt=\"Five Queen's Anniversary Prizes\"></a>\n  </div>\n  <div class=\"region region-footer_last\">\n    <div class=\"social\">\n      <a href=\"https://instagram.com/theuniversityofsheffield\"><img src=\"//cdn.sheffield.ac.uk/sites/default/files/styles/original/public/2022-10/social-in.png\" width=\"34\" height=\"34\" alt=\"Instagram logo\"></a>\n      <a href=\"https://www.linkedin.com/school/university-of-sheffield/\"><img src=\"//cdn.sheffield.ac.uk/sites/default/files/styles/original/public/2022-10/social-li.png\" width=\"34\" height=\"34\" alt=\"LinkedIn\"></a>\n      <a href=\"https://www.tiktok.com/@sheffielduni\"><img src=\"//cdn.sheffield.ac.uk/sites/default/files/styles/original/public/2022-10/social-tt.png\" width=\"34\" height=\"34\" alt=\"TikTok\"></a>\n      <a href=\"https://www.weibo.com/sheffielduni\"><img src=\"//cdn.sheffield.ac.uk/sites/default/files/styles/original/public/2022-10/social-wb.png\" width=\"34\" height=\"34\" alt=\"Weibo\"></a>\n    </div>\n  </div>\n</div>"]}
