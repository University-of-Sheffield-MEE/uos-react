{
  "componentName": "PgCourseImage",
  "atomicType": "molecule",
  "childComponents": [],
  "description": "Responsive course image block used on postgraduate course pages, containing a picture element with multiple breakpoint-specific source sets.",
  "rootElement": "div",
  "rootClassName": "pg-course-image",
  "selectorsCovered": [".pg-course-image", ".pg-course-image img"],
  "props": [
    {
      "name": "src",
      "type": "string",
      "required": true,
      "mapsTo": { "element": "img", "attribute": "src" }
    },
    {
      "name": "alt",
      "type": "string",
      "required": true,
      "mapsTo": { "element": "img", "attribute": "alt" }
    },
    {
      "name": "width",
      "type": "number",
      "required": false,
      "default": "375",
      "mapsTo": { "element": "img", "attribute": "width" }
    },
    {
      "name": "height",
      "type": "number",
      "required": false,
      "default": "211",
      "mapsTo": { "element": "img", "attribute": "height" }
    },
    {
      "name": "sources",
      "type": "Array<{ srcSet: string; media?: string; type?: string; sizes?: string; width?: number; height?: number }>",
      "required": false,
      "mapsTo": { "element": "picture source", "attribute": "srcset" }
    }
  ],
  "subcomponents": [],
