          { "src": "//cdn.sheffield.ac.uk/sites/default/files/styles/responsive_thumbnail_128px_x_288px_/public/2021-06/EPSRC%20logo.jpg", "alt": "EPSRC logo", "href": "https://www.ukri.org/", "ariaLabel": "EPSRC" },
          { "src": "//cdn.sheffield.ac.uk/sites/default/files/styles/responsive_thumbnail_128px_x_288px_/public/2024-04/nhs-logo-880x4951.jpeg.jpg", "alt": "NHS logo" }
