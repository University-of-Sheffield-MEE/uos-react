          { "src": "//cdn.sheffield.ac.uk/sites/default/files/styles/responsive_thumbnail_128px_x_288px_/public/2021-07/advocatelogo.jpg", "alt": "The ADVOCATE project logo", "href": "http://www.sheffield.ac.uk/advocate-eu", "ariaLabel": "ADVOCATE Project" }
