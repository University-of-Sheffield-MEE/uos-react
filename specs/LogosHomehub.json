{
  "componentName": "LogosHomehub",
  "atomicType": "molecule",
  "childComponents": [],
  "description": "A full-width scrollable row of partner or sponsor logos, optionally with a descriptive paragraph, used on hub pages.",
  "rootElement": "div",
  "rootClassName": "logos-homehub",
  "selectorsCovered": [
    ".logos-homehub",
    ".logos-homehub .row-width",
    ".logos-homehub .row-width .logo-container",
    ".logos-homehub .row-width .logo-container .home-hub-logos",
    ".logos-homehub .row-width .logo-container img",
    ".logos-homehub .scrollarrows button",
    ".logos-homehub p"
  ],
  "props": [
    {
      "name": "description",
      "type": "string",
      "required": false,
      "mapsTo": { "element": ".row-width p", "attribute": "innerText" }
    },
    {
      "name": "logos",
      "type": "Array<{ src: string; alt: string; href?: string; ariaLabel?: string }>",
      "required": true,
      "mapsTo": { "element": ".logo-container .home-hub-logos", "attribute": "innerText" }
    },
    {
      "name": "showScrollArrows",
      "type": "boolean",
      "required": false,
      "default": "false",
      "mapsTo": { "togglesClass": "scrollarrows", "on": ".row-width" }
    }
  ],
  "subcomponents": [],
  "stories": [
