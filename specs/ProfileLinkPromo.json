  "selectorsCovered": [
    ".profile-link-promo",
    ".profile-link-promo a",
    ".profile-link-promo a:last-of-type",
    ".profile-link-promo span",
    ".profile-link-promo span:last-of-type"
  ],
  "props": [
    {
      "name": "links",
      "type": "Array<{ label: string; href: string }>",
      "required": true,
      "mapsTo": { "element": "p a", "attribute": "innerText" }
    }
  ],
  "subcomponents": [],
