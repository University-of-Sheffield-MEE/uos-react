{
  "componentName": "StapCard",
  "atomicType": "molecule",
  "childComponents": ["StapContact", "ProfilePicModal"],
  "description": "Staff profile card displaying a staff member's photo (or initials placeholder), name, job title, department, optional description, and contact details.",
  "rootElement": "div",
  "rootClassName": "stap-card",
  "selectorsCovered": [
    ".stap-card",
    ".stap-card__info",
    ".stap-card .summary-text",
    ".stap-card .summary-text h3",
    ".stap-card .summary-text a",
    ".stap-card .profilepic",
    ".stap-card .profilepic img",
    ".stap-card .enlarge",
    ".stap-card .profilepic-modal",
    ".stap-card .deptname",
    ".stap-card p",
    ".stap-card .profileinitials",
    ".staffcardindex > div .stap-card",
    ".staffcardindex > div .stap-card a[href^=\"mailto:\"]",
    ".staffcardindex > div .stap-card .enlarge",
    ".staffcardindex > div .stap-card .close",
    ".staffcardindex > div .stap-card .profilepic-modal"
  ],
  "props": [
    {
      "name": "href",
      "type": "string",
      "required": true,
      "mapsTo": { "element": "a.stretched-link", "attribute": "href" }
    },
    {
      "name": "ariaLabel",
      "type": "string",
      "required": true,
      "mapsTo": { "element": "> a", "attribute": "aria-label" }
    },
    {
      "name": "name",
      "type": "string",
      "required": true,
      "mapsTo": { "element": ".stap-card__info h3 a", "attribute": "innerText" }
    },
    {
      "name": "jobTitle",
      "type": "string",
      "required": true,
      "mapsTo": { "element": ".jobtitle", "attribute": "innerText" }
    },
    {
      "name": "deptName",
      "type": "string",
      "required": true,
      "mapsTo": { "element": ".deptname", "attribute": "innerText" }
    },
    {
      "name": "description",
      "type": "string",
      "required": false,
      "mapsTo": { "element": ".stap-card__info a > p", "attribute": "innerText" }
    },
    {
      "name": "imageSrc",
      "type": "string",
      "required": false,
      "mapsTo": { "element": ".profilepic img", "attribute": "src" }
    },
    {
      "name": "imageAlt",
      "type": "string",
      "required": false,
      "mapsTo": { "element": ".profilepic img", "attribute": "alt" }
    },
    {
      "name": "modalImageSrc",
      "type": "string",
      "required": false,
      "mapsTo": { "element": ".profilepic-modal img", "attribute": "src" }
    },
    {
      "name": "profileInitials",
      "type": "string",
      "required": false,
      "mapsTo": { "element": ".profileinitials", "attribute": "innerText" }
    },
    {
      "name": "email",
      "type": "string",
      "required": false,
      "mapsTo": { "element": ".stap-contact dd a[href^=\"mailto:\"]", "attribute": "innerText" }
    },
    {
      "name": "phone",
      "type": "string",
      "required": false,
      "mapsTo": { "element": ".stap-contact .telnum", "attribute": "innerText" }
    }
  ],
  "subcomponents": [],
